# Copy to frontend/.env and point at your ESP32's IP or mDNS hostname for local dev.
# The dev frontend opens a WebSocket to ws://<VITE_ESP_ID>/ws for sensor reps.
# For production HTTPS deployments, use VITE_ESP_WS_URL with a wss:// URL.
# Leave unset to disable the ESP integration (MediaPipe still works).
VITE_ESP_ID=192.168.1.50
# VITE_ESP_WS_URL=wss://example.com/ws
